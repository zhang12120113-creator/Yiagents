# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# FRED (Federal Reserve macro data: rates, inflation, labor, growth). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
#FRED_API_KEY=
# Alpha Vantage (daily price/volume + fundamentals). Free key: https://www.alphavantage.co/support/#api-key
#ALPHA_VANTAGE_API_KEY=
# Reddit (optional OAuth for richer post data + bypass of public-feed 429).
# Create a "script" app at https://www.reddit.com/prefs/apps; use any URL as
# the redirect URI (the client_credentials grant never redirects). With both
# REDDIT_CLIENT_ID and REDDIT_CLIENT_SECRET set, the sentiment analyst's Reddit
# source pulls score/comment-count posts from oauth.reddit.com; without them the
# RSS feed path runs unchanged.
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=
#REDDIT_USER_AGENT=

# Optional: a custom OpenAI-compatible endpoint (vLLM, LM Studio, llama.cpp,
# relay). Select provider "openai_compatible" and set the base URL; the key is
# optional (local servers need none).
#OPENAI_COMPATIBLE_API_KEY=

# AWS Bedrock (provider "bedrock", install with: pip install ".[bedrock]").
# Auth uses the standard AWS credential chain; set the region (and optionally a
# named profile). No single API key.
#AWS_DEFAULT_REGION=us-west-2
#AWS_PROFILE=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Storage / output paths (optional). Override where YiAgents writes reports,
# caches downloaded market data, and stores its analyst memory log. Each
# defaults to a per-user directory under the OS data home; set these to
# relocate them (e.g. onto faster/larger storage). Read directly — not via
# the typed DEFAULT_CONFIG override block below.
#YIAGENTS_RESULTS_DIR=
#YIAGENTS_CACHE_DIR=
#YIAGENTS_MEMORY_LOG_PATH=

# Optional: override DEFAULT_CONFIG without editing code.
# Any YIAGENTS_* variable below, when set, replaces the matching key
# in yiagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).
#YIAGENTS_LLM_PROVIDER=openai
#YIAGENTS_DEEP_THINK_LLM=gpt-5.4
#YIAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#YIAGENTS_LLM_BACKEND_URL=
#YIAGENTS_OUTPUT_LANGUAGE=English
#YIAGENTS_MAX_DEBATE_ROUNDS=1
#YIAGENTS_MAX_RISK_ROUNDS=1
#YIAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#YIAGENTS_TEMPERATURE=0.0
# Provider-specific reasoning/thinking depth (optional; unset = provider
# default). Setting one also skips the matching prompt.
#YIAGENTS_OPENAI_REASONING_EFFORT=medium
#YIAGENTS_GOOGLE_THINKING_LEVEL=high
#YIAGENTS_ANTHROPIC_EFFORT=high

# --- Transport / retry hardening (zero impact on what is sent to the model) ---
# Per-request LLM read timeout (seconds). DeepSeek occasionally leaves a
# half-open socket (accepts the connection but never responds); without a
# timeout the call blocks forever and hangs the whole batch. Setting this
# makes such a call raise APITimeoutError so the SDK's built-in retry
# (max_retries below) can resend — usually recovering. Real calls land in
# <10s; 120s covers the heaviest reasoning call while still recovering from
# rare stalls. Read inline by yiagents/llm_clients/openai_client.py:get_llm().
#YIAGENTS_LLM_TIMEOUT_S=120
# Per-call retry count forwarded to the provider client (max_retries). Default
# 2 == langchain-openai's own default, so UNSET behaviour is byte-equivalent.
# Lower it during flaky periods (run_robust's per-ticker rerun is the outer
# safety net, so a single call need not retry itself to death).
#YIAGENTS_LLM_MAX_RETRIES=2
# Share one httpx.Client (keepalive) across every LLM call so worker graphs
# reuse TLS/SOCKS5-proxy connections. Transport-only — it changes nothing
# about what is sent to the model. Only wired for OpenAI-compatible providers
# (DeepSeek direct qualifies). Off by default.
#YIAGENTS_HTTP_KEEPALIVE=true
# Binance perp data vendor: read the X-MBX-USED-WEIGHT-1M response header and
# back off before the per-IP per-minute weight ceiling (fapi default 2400/min)
# so the vendor avoids a 429 instead of only reacting to one. Off by default =
# the vendor neither reads the header nor sleeps (byte-equivalent). Only
# consulted when binance_proactive_backoff is on; the reactive 429/418 path is
# always the floor.
#YIAGENTS_BINANCE_PROACTIVE_BACKOFF=false
#YIAGENTS_BINANCE_WEIGHT_THRESHOLD=2400

# --- Telemetry / analyst parallelism (observation only; off by default) -----
# Node-level wall-time + token telemetry: wraps every graph node handler,
# dumps node_perf_<date>.json next to full_states_log. Off = handlers pass
# through unwrapped (byte-equivalent). scripts/run_baseline.py --profile
# turns this on for a 1-ticker smoke.
#YIAGENTS_NODE_PERF_TELEMETRY=false
# Fan the 4 analysts out inside one wrapper node (each gets its own sub-graph
# state, so the shared `messages` / clear_node coupling is structurally
# avoided). OFF by default = today's serial analyst chain verbatim; flip on
# ONLY after scripts/run_analyst_parallel_ab.py passes its gate. Caps nested
# concurrency: analyst_parallel only engages when batch_workers*4 <=
# analyst_parallel_max_threads, else it silently falls back to serial.
#YIAGENTS_ANALYST_PARALLEL=false
#YIAGENTS_ANALYST_PARALLEL_MAX_THREADS=16
